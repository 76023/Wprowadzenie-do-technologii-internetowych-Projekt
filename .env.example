# Lokalne uruchomienie (SQLite)
PORT=3000
NODE_ENV=development
SESSION_SECRET=zmien-ten-sekret-na-hostingu
DB_PATH=./baza/isaczytac.sqlite

# Produkcja (Render) - PostgreSQL
# Ustaw DATABASE_URL tylko w panelu Render. Nie commituj prawdziwego URL.
# Gdy DATABASE_URL jest ustawione, aplikacja automatycznie przelacza sie na PostgreSQL.
# DATABASE_URL=postgres://uzytkownik:haslo@host:5432/baza?sslmode=require
